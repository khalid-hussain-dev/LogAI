        C5["Redis Pub/Sub channels"]
    end

    subgraph Processing["Processing pipeline"]
        D1["AnomalyService"]
        D2["Stream worker"]
        D3["Parser layer\nJSON, Nginx, Python/Java, Syslog"]
        D4["Notification service"]
    end

    subgraph Outputs["Outbound channels"]
        E1["Slack"]
        E2["SMTP email"]
        E3["Custom webhook"]
    end

